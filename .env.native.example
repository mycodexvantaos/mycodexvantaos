# MyCodexVantaOS Native Configuration
# 使用本地實現，零外部依賴，完全可離線運行

# ==================== 運行時模式 ====================
# native: 僅使用本地實現
RUNTIME_MODE=native
MYCODEXVANTAOS_RUNTIME_MODE=native

# ==================== 降級策略 ====================
# Native 模式下不需要降級
MYCODEXVANTAOS_FALLBACK_ENABLED=false

# ==================== 日誌配置 ====================
MYCODEXVANTAOS_LOG_LEVEL=debug

# ==================== 存儲配置 ====================
# 本地存儲類型: memory | file | sqlite | indexeddb
MYCODEXVANTAOS_STORAGE_TYPE=sqlite
MYCODEXVANTAOS_STORAGE_PATH=./data/local.db

# ==================== 認證配置 ====================
# Native JWT 認證
MYCODEXVANTAOS_AUTH_PROVIDER=native
MYCODEXVANTAOS_AUTH_JWT_SECRET=your-local-jwt-secret-change-me

# ==================== 指標配置 ====================
MYCODEXVANTAOS_METRICS_ENABLED=true

# ==================== 外部 API（不需要）====================
# Native 模式下不使用外部 API
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
# GOOGLE_API_KEY=

# ==================== 數據庫配置 ====================
# 使用本地 SQLite
DATABASE_URL=sqlite://./data/local.db

# ==================== 功能開關 ====================
# 啟用離線模式
OFFLINE_MODE=true

# 啟用調試模式
DEBUG_MODE=true