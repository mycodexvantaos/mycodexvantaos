# ====== MyCodexVantaOS Local Runtime Environment ======

# Baseline Runtime Configuration
MYCODEXVANTAOS_CORE_ENVIRONMENT=development
MYCODEXVANTAOS_CORE_LOG_LEVEL=debug
MYCODEXVANTAOS_CORE_RUNTIME_MODE=native

# Provider Layer: Database Capability
MYCODEXVANTAOS_DATABASE_POSTGRES_URL="postgresql://postgres:postgres@localhost:5432/mycodexvantaos?schema=public"

# Provider Layer: Cache/Queue Capability
MYCODEXVANTAOS_CACHE_REDIS_URL="redis://localhost:6379"

# Core Services Endpoints
MYCODEXVANTAOS_AUTH_ENDPOINT="http://localhost:3001"
MYCODEXVANTAOS_PORTAL_ENDPOINT="http://localhost:3002"
MYCODEXVANTAOS_REGISTRY_ENDPOINT="http://localhost:3003"

# Authentication Specifications
MYCODEXVANTAOS_AUTH_JWT_SECRET="dev-secret-change-in-production"
MYCODEXVANTAOS_AUTH_JWT_EXPIRES_IN=3600

# Provider Layer: Storage Capability
MYCODEXVANTAOS_STORAGE_DEFAULT_PROVIDER="storage-local"
MYCODEXVANTAOS_STORAGE_LOCAL_PATH="./storage"
