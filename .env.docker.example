# ====== MyCodexVantaOS Docker/Connected Runtime Environment ======

# Baseline Runtime Configuration
MYCODEXVANTAOS_CORE_ENVIRONMENT=development
MYCODEXVANTAOS_CORE_LOG_LEVEL=info
MYCODEXVANTAOS_CORE_RUNTIME_MODE=hybrid

# Provider Layer: Database Capability (Docker Net)
MYCODEXVANTAOS_DATABASE_POSTGRES_URL="postgresql://postgres:postgres@postgres:5432/mycodexvantaos?schema=public"

# Provider Layer: Cache/Queue Capability (Docker Net)
MYCODEXVANTAOS_CACHE_REDIS_URL="redis://redis:6379"

# Core Services Endpoints (Docker internal DNS)
MYCODEXVANTAOS_AUTH_ENDPOINT="http://mycodexvantaos-core-auth:3001"
MYCODEXVANTAOS_PORTAL_ENDPOINT="http://mycodexvantaos-core-portal:3002"
MYCODEXVANTAOS_REGISTRY_ENDPOINT="http://mycodexvantaos-core-registry:3003"

# Authentication Specifications
MYCODEXVANTAOS_AUTH_JWT_SECRET="dev-secret-change-in-production"
MYCODEXVANTAOS_AUTH_JWT_EXPIRES_IN=3600

# Provider Layer: Storage Capability
MYCODEXVANTAOS_STORAGE_DEFAULT_PROVIDER="storage-local"
MYCODEXVANTAOS_STORAGE_LOCAL_PATH="/data/storage"
