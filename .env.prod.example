# ====== MyCodexVantaOS Production/Cloud Runtime Environment ======

# Baseline Runtime Configuration
MYCODEXVANTAOS_CORE_ENVIRONMENT=production
MYCODEXVANTAOS_CORE_LOG_LEVEL=warn
MYCODEXVANTAOS_CORE_RUNTIME_MODE=connected

# Provider Layer: Database Capability (Cloud RDS/Managed)
MYCODEXVANTAOS_DATABASE_POSTGRES_URL="postgresql://${MYCODEXVANTAOS_DB_USER}:${MYCODEXVANTAOS_DB_PASSWORD}@${MYCODEXVANTAOS_DB_HOST}:5432/mycodexvantaos?schema=public"

# Provider Layer: Cache/Queue Capability (Cloud ElastiCache/Managed)
MYCODEXVANTAOS_CACHE_REDIS_URL="redis://${MYCODEXVANTAOS_REDIS_HOST}:6379"

# Core Services Endpoints (Service Discovery/Ingress)
MYCODEXVANTAOS_AUTH_ENDPOINT="https://auth.mycodexvantaos.internal"
MYCODEXVANTAOS_PORTAL_ENDPOINT="https://api.mycodexvantaos.internal"
MYCODEXVANTAOS_REGISTRY_ENDPOINT="https://registry.mycodexvantaos.internal"

# Authentication Specifications (Vault/KMS)
MYCODEXVANTAOS_AUTH_JWT_SECRET="${MYCODEXVANTAOS_VAULT_JWT_SECRET}"
MYCODEXVANTAOS_AUTH_JWT_EXPIRES_IN=3600

# Provider Layer: Storage Capability (Cloud Blob)
MYCODEXVANTAOS_STORAGE_DEFAULT_PROVIDER="storage-s3"
MYCODEXVANTAOS_STORAGE_S3_BUCKET="mycodexvantaos-prod"
MYCODEXVANTAOS_STORAGE_S3_REGION="us-east-1"
MYCODEXVANTAOS_STORAGE_S3_ENDPOINT="${MYCODEXVANTAOS_S3_ENDPOINT}"
