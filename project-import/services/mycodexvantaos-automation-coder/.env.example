# CodexvantaOS — Environment Configuration
# Philosophy: Native-first / Provider-agnostic
# All variables are OPTIONAL — Native mode works with zero config

# Operational Mode: native | connected | hybrid (auto-detected if omitted)
# CODEXVANTA_MODE=native

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info


# Database Provider (native: SQLite, connected: Supabase/Postgres)
# DATABASE_PROVIDER=native
# DATABASE_URL=postgresql://...
# SUPABASE_URL=https://...
# SUPABASE_KEY=...

# Storage Provider (native: filesystem, connected: S3/GCS)
# STORAGE_PROVIDER=native
# STORAGE_PATH=./data/storage
# S3_BUCKET=...
