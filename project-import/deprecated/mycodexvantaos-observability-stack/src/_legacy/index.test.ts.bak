/**
 * CodexvantaOS — observability-stack Enhanced Tests
 * Provider-chain aware test suite
 *
 * Tests:
 *   1. Service instantiation
 *   2. Method contract compliance
 *   3. Provider dependency declaration
 *   4. Architecture compliance (no direct external imports)
 *
 * Run: CODEXVANTA_MODE=native pnpm run test
 */

import { describe, it, expect } from 'vitest';
import { LoggingService } from '../src/services/logging.service.js';
import { MetricsService } from '../src/services/metrics.service.js';
import { TracingService } from '../src/services/tracing.service.js';
import { AlertingService } from '../src/services/alerting.service.js';

// ─── Provider Dependencies Declaration ──────────────────────
const PROVIDER_DEPS: Record<string, string[]> = {
  LoggingService: ['observability', 'storage'],
  MetricsService: ['observability', 'stateStore'],
  TracingService: ['observability', 'stateStore'],
  AlertingService: ['observability', 'notification', 'stateStore'],
};

describe('LoggingService', () => {
  it('should be instantiable', () => {
    const service = new LoggingService();
    expect(service).toBeDefined();
    expect(service).toBeInstanceOf(LoggingService);
  });

  it('should implement log method', () => {
    const service = new LoggingService();
    expect(typeof service.log).toBe('function');
  });

  it('should implement info method', () => {
    const service = new LoggingService();
    expect(typeof service.info).toBe('function');
  });

  it('should implement warn method', () => {
    const service = new LoggingService();
    expect(typeof service.warn).toBe('function');
  });

  it('should implement error method', () => {
    const service = new LoggingService();
    expect(typeof service.error).toBe('function');
  });

  it('should implement query method', () => {
    const service = new LoggingService();
    expect(typeof service.query).toBe('function');
  });

  it('should declare 2 provider dependencies', () => {
    const deps = PROVIDER_DEPS.LoggingService;
    expect(deps).toBeDefined();
    expect(deps).toHaveLength(2);
    expect(deps).toContain('observability');
    expect(deps).toContain('storage');
  });

});

