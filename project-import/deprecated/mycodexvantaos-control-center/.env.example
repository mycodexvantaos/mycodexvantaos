# CodexvantaOS — Environment Configuration
# Philosophy: Native-first / Provider-agnostic
# All variables are OPTIONAL — Native mode works with zero config

# Operational Mode: native | connected | hybrid (auto-detected if omitted)
# CODEXVANTA_MODE=native

# Server
PORT=3000
NODE_ENV=development
LOG_LEVEL=info


# State Store Provider (native: file, connected: Redis)
# STATE_PROVIDER=native
# STATE_STORE_PATH=./data/state

# Repo Provider (native: git CLI, connected: GitHub API)
# REPO_PROVIDER=native
# GITHUB_TOKEN=...

# Notification Provider (native: console/file, connected: Slack)
# NOTIFICATION_PROVIDER=native
# SLACK_WEBHOOK_URL=...
