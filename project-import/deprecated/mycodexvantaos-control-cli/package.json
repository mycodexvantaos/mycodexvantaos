{
  "name": "@mycodexvantaos/control-cli",
  "version": "0.1.0",
  "private": true,
  "description": "CodexvantaOS command-line interface",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "codexvanta": "dist/bin/codexvanta.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/bin/codexvanta.ts",
    "start": "node dist/bin/codexvanta.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src/ tests/ --ext .ts",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist coverage"
  },
  "dependencies": {
    "commander": "^12.0.0",
    "pino": "^9.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "jest-junit": "^16.0.0",
    "ts-jest": "^29.1.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0"
  }
}
