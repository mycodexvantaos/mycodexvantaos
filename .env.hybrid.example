# MyCodexVantaOS Hybrid Configuration
# 優先使用外部服務，失敗時降級到本地實現

# ==================== 運行時模式 ====================
# hybrid: 優先外部，可降級到本地
RUNTIME_MODE=hybrid
MYCODEXVANTAOS_RUNTIME_MODE=hybrid

# ==================== 降級策略 ====================
# 啟用降級，當外部服務不可用時使用本地實現
MYCODEXVANTAOS_FALLBACK_ENABLED=true

# ==================== 日誌配置 ====================
MYCODEXVANTAOS_LOG_LEVEL=info

# ==================== 存儲配置 ====================
# 使用本地 SQLite 作為主存儲，可選同步到雲端
MYCODEXVANTAOS_STORAGE_TYPE=sqlite
MYCODEXVANTAOS_STORAGE_PATH=./data/hybrid.db

# ==================== 認證配置 ====================
# 混合認證：優先 OAuth，降級到本地 JWT
MYCODEXVANTAOS_AUTH_PROVIDER=hybrid
MYCODEXVANTAOS_AUTH_JWT_SECRET=your-hybrid-jwt-secret-change-me

# ==================== 指標配置 ====================
MYCODEXVANTAOS_METRICS_ENABLED=true
# 可選：推送到 Prometheus Push Gateway
# MYCODEXVANTAOS_METRICS_PUSH_URL=http://prometheus-pushgateway:9091

# ==================== 外部 API（可選）====================
# 至少配置一個 AI API 用於代碼合成
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_API_KEY=your-google-api-key

# ==================== 數據庫配置 ====================
# 可選：連接到外部數據庫
# DATABASE_URL=postgresql://user:password@localhost:5432/mycodexvantaos

# ==================== 功能開關 ====================
# 啟用離線降級
OFFLINE_FALLBACK=true

# 啟用調試模式
DEBUG_MODE=false