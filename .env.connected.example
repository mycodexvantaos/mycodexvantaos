# MyCodexVantaOS Connected Configuration
# 僅使用外部服務，需要網路連接

# ==================== 運行時模式 ====================
# connected: 僅使用外部服務
RUNTIME_MODE=connected
MYCODEXVANTAOS_RUNTIME_MODE=connected

# ==================== 降級策略 ====================
# Connected 模式下不啟用降級，外部服務不可用時會失敗
MYCODEXVANTAOS_FALLBACK_ENABLED=false

# ==================== 日誌配置 ====================
MYCODEXVANTAOS_LOG_LEVEL=warn

# ==================== 存儲配置 ====================
# 使用雲端存儲服務
MYCODEXVANTAOS_STORAGE_TYPE=s3
# MYCODEXVANTAOS_STORAGE_PATH=s3://my-bucket/path

# ==================== 認證配置 ====================
# 使用外部認證服務（OAuth/OIDC）
MYCODEXVANTAOS_AUTH_PROVIDER=oauth
# MYCODEXVANTAOS_AUTH_OAUTH_CLIENT_ID=your-client-id
# MYCODEXVANTAOS_AUTH_OAUTH_CLIENT_SECRET=your-client-secret
# MYCODEXVANTAOS_AUTH_OAUTH_ISSUER=https://your-auth-provider.com

# ==================== 指標配置 ====================
MYCODEXVANTAOS_METRICS_ENABLED=true
MYCODEXVANTAOS_METRICS_PUSH_URL=https://prometheus.example.com/api/v1/push

# ==================== 外部 API（必需）====================
# 至少配置一個 AI API 用於代碼合成
ANTHROPIC_API_KEY=your-anthropic-api-key
# OPENAI_API_KEY=your-openai-api-key
# GOOGLE_API_KEY=your-google-api-key

# ==================== 數據庫配置 ====================
# 連接到外部數據庫
DATABASE_URL=postgresql://user:password@your-db-host:5432/mycodexvantaos

# ==================== 功能開關 ====================
# 禁用離線模式
OFFLINE_MODE=false

# 禁用調試模式
DEBUG_MODE=false

# ==================== 生產環境配置 ====================
NODE_ENV=production